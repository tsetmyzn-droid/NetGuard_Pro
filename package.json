{
  "name": "netguard-pro",
  "private": true,
  "version": "1.0.0",
  "description": "NetGuard Pro - Advanced Network Management and Security Dashboard",
  "author": "NetGuard Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsetmyzn-droid/Router-Master-Control-V1"
  },
  "homepage": "https://github.com/tsetmyzn-droid/Router-Master-Control-V1",
  "main": "electron/main.cjs",
  "type": "module",
  "build": {
    "appId": "com.netguardpro.app",
    "productName": "NetGuard Pro",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "portable",
      "icon": "public/favicon.ico"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  },
  "scripts": {
    "dev": "tsx server.ts",
    "start": "tsx server.ts",
    "build": "vite build",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "electron:dev": "electron .",
    "electron:build": "npm run build && electron-builder",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:android": "npx cap open android",
    "ai:fix": "node scripts/auto-fix.js"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "idb-keyval": "^6.2.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "sqlite3": "^6.0.1",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
